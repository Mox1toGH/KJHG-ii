# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_ENGINE=sqlite
DB_NAME=db.sqlite3

# Public app URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email
# Use console backend locally if you only want emails printed in the terminal.
# Use SMTP backend when emails should be delivered to real inboxes.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@example.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Notifications
# Default notification delivery preferences for new users
DEFAULT_EMAIL_NOTIFICATIONS_ENABLED=False
DEFAULT_IN_APP_NOTIFICATIONS_ENABLED=True

# Google OAuth
# Must match the Web client ID used by Google Identity Services on the frontend.
GOOGLE_OAUTH_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_BASE_URL=ws://localhost:8000
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
